// Brivia - Creator Subscription Platform
// Prisma Schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum UserRole {
  FAN
  CREATOR
  ADMIN
}

enum ContentType {
  PHOTO
  VIDEO
  TEXT
  BUNDLE
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
  INCOMPLETE
  PAUSED
}

enum BillingInterval {
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum RequestStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  DELIVERED
  REJECTED
  CANCELED
}

enum PayoutStatus {
  PENDING
  IN_TRANSIT
  PAID
  FAILED
  CANCELED
}

enum TransactionType {
  SUBSCRIPTION
  TIP
  PPV_MESSAGE
  PPV_POST
  CONTENT_REQUEST
  PAYOUT
  REFUND
  PLATFORM_FEE
}

enum NotificationType {
  NEW_SUBSCRIBER
  NEW_TIP
  NEW_MESSAGE
  NEW_COMMENT
  NEW_LIKE
  POST_PUBLISHED
  CONTENT_REQUEST
  PAYOUT_SENT
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_CANCELED
  VERIFICATION_APPROVED
  SYSTEM
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  REQUIRES_RESUBMISSION
}

// ─── Core Models ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  role      UserRole @default(FAN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  creatorProfile      CreatorProfile?
  fanProfile          FanProfile?
  subscriptions       Subscription[]        @relation("SubscriberSubscriptions")
  sentMessages        Message[]             @relation("SentMessages")
  conversations       Conversation[]        @relation("FanConversations")
  sentTips            Tip[]                 @relation("SentTips")
  contentRequests     ContentRequest[]      @relation("RequestedBy")
  paymentMethods      PaymentMethod[]
  transactions        Transaction[]         @relation("UserTransactions")
  notifications       Notification[]
  auditLogs           AuditLog[]
  postLikes           PostLike[]
  postComments        PostComment[]
  postPurchases       PostPurchase[]

  @@index([clerkId])
  @@index([email])
  @@index([role])
}

model CreatorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  displayName     String
  slug            String   @unique
  bio             String?  @db.Text
  avatarKey       String?
  bannerKey       String?
  tags            String[]
  isVerified      Boolean  @default(false)
  isActive        Boolean  @default(true)
  platformFee     Float    @default(0.20) // 20% platform cut

  // Stripe Connect
  stripeAccountId String?  @unique
  stripeOnboardingComplete Boolean @default(false)

  // Stats (denormalized for perf)
  subscriberCount Int      @default(0)
  postCount       Int      @default(0)
  totalEarnings   Float    @default(0)

  // AI Agent
  isAgent           Boolean  @default(false)
  agentSystemPrompt String?  @db.Text

  // Paid DMs
  dmPrice         Float?   // Price per DM in cents (null = free)
  dmEnabled       Boolean  @default(false)

  // Social links
  websiteUrl      String?
  twitterHandle   String?
  instagramHandle String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionTiers  SubscriptionTier[]
  posts              Post[]
  conversations      Conversation[]      @relation("CreatorConversations")
  receivedTips       Tip[]               @relation("ReceivedTips")
  contentRequests    ContentRequest[]    @relation("CreatorRequests")
  payouts            Payout[]
  transactions       Transaction[]       @relation("CreatorTransactions")
  verification       CreatorVerification?

  @@index([slug])
  @@index([userId])
  @@index([isActive])
}

model FanProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  displayName String
  avatarKey   String?
  totalSpent  Float   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Subscription Models ─────────────────────────────────────────────────────

model SubscriptionTier {
  id               String          @id @default(cuid())
  creatorProfileId String
  name             String
  description      String?
  price            Float           // in dollars
  interval         BillingInterval @default(MONTHLY)
  stripePriceId    String?         @unique
  stripeProductId  String?

  // Perks
  dmAccess         Boolean         @default(false)
  exclusiveContent Boolean         @default(true)
  requestAccess    Boolean         @default(false)
  maxDmMessages    Int?            // null = unlimited

  // Display
  isActive         Boolean         @default(true)
  sortOrder        Int             @default(0)
  color            String?         // for UI theming

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  subscriptions  Subscription[]
  requiredByPosts Post[]

  @@index([creatorProfileId])
  @@index([stripePriceId])
}

model Subscription {
  id                     String             @id @default(cuid())
  subscriberId           String
  tierId                 String
  stripeSubscriptionId   String?            @unique
  stripeCustomerId       String?
  status                 SubscriptionStatus @default(ACTIVE)
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  canceledAt             DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriber User             @relation("SubscriberSubscriptions", fields: [subscriberId], references: [id])
  tier       SubscriptionTier @relation(fields: [tierId], references: [id])

  @@unique([subscriberId, tierId])
  @@index([subscriberId])
  @@index([tierId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

// ─── Content Models ──────────────────────────────────────────────────────────

model Post {
  id               String      @id @default(cuid())
  creatorProfileId String
  title            String?
  body             String?     @db.Text
  contentType      ContentType @default(TEXT)

  // Paywall
  isPaid           Boolean     @default(false)
  price            Float?      // for PPV posts
  requiredTierId   String?     // require subscription tier

  // Publishing
  isPublished      Boolean     @default(false)
  publishedAt      DateTime?
  scheduledAt      DateTime?

  // Stats
  viewCount        Int         @default(0)
  likeCount        Int         @default(0)
  commentCount     Int         @default(0)
  purchaseCount    Int         @default(0)

  // Pinned
  isPinned         Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorProfile CreatorProfile    @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  requiredTier   SubscriptionTier? @relation(fields: [requiredTierId], references: [id])
  media          PostMedia[]
  likes          PostLike[]
  comments       PostComment[]
  purchases      PostPurchase[]

  @@index([creatorProfileId])
  @@index([isPublished, publishedAt])
  @@index([isPaid])
}

model PostMedia {
  id            String    @id @default(cuid())
  postId        String
  mediaType     MediaType
  r2Key         String?
  muxAssetId    String?
  muxPlaybackId String?
  blurHash      String?
  thumbnailKey  String?
  width         Int?
  height        Int?
  duration      Float?    // for video/audio in seconds
  fileSize      Int?      // bytes
  mimeType      String?
  sortOrder     Int       @default(0)

  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([muxAssetId])
}

model PostLike {
  id     String @id @default(cuid())
  postId String
  userId String

  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostComment {
  id       String  @id @default(cuid())
  postId   String
  userId   String
  body     String  @db.Text
  parentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post     Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   PostComment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  PostComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([userId])
}

model PostPurchase {
  id              String @id @default(cuid())
  postId          String
  userId          String
  stripePaymentId String?
  amount          Float

  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// ─── Messaging Models ────────────────────────────────────────────────────────

model Conversation {
  id               String  @id @default(cuid())
  creatorProfileId String
  fanUserId        String
  isUnlocked       Boolean @default(false)
  dmPrice          Float?  // if creator charges to unlock DMs
  lastMessageAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorProfile CreatorProfile @relation("CreatorConversations", fields: [creatorProfileId], references: [id], onDelete: Cascade)
  fan            User           @relation("FanConversations", fields: [fanUserId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([creatorProfileId, fanUserId])
  @@index([creatorProfileId])
  @@index([fanUserId])
  @@index([lastMessageAt])
}

model Message {
  id             String  @id @default(cuid())
  conversationId String
  senderId       String
  body           String? @db.Text
  mediaKey       String?
  mediaType      MediaType?

  // PPV message
  isPPV          Boolean @default(false)
  ppvPrice       Float?
  ppvUnlocked    Boolean @default(false)
  ppvUnlockedAt  DateTime?

  // Read status
  isRead         Boolean @default(false)
  readAt         DateTime?

  // Tip in DM
  tipAmount      Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ─── Payment Models ──────────────────────────────────────────────────────────

model Tip {
  id               String  @id @default(cuid())
  senderId         String
  creatorProfileId String
  amount           Float
  message          String?
  stripePaymentId  String? @unique
  isAnonymous      Boolean @default(false)

  createdAt DateTime @default(now())

  sender         User           @relation("SentTips", fields: [senderId], references: [id])
  creatorProfile CreatorProfile @relation("ReceivedTips", fields: [creatorProfileId], references: [id])

  @@index([senderId])
  @@index([creatorProfileId])
}

model ContentRequest {
  id               String        @id @default(cuid())
  requestedById    String
  creatorProfileId String
  title            String
  description      String        @db.Text
  budget           Float
  status           RequestStatus @default(PENDING)
  deliveredPostId  String?
  rejectionReason  String?
  stripePaymentId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestedBy    User           @relation("RequestedBy", fields: [requestedById], references: [id])
  creatorProfile CreatorProfile @relation("CreatorRequests", fields: [creatorProfileId], references: [id])

  @@index([requestedById])
  @@index([creatorProfileId])
  @@index([status])
}

model PaymentMethod {
  id                    String  @id @default(cuid())
  userId                String
  stripePaymentMethodId String  @unique
  stripeCustomerId      String
  type                  String  // card, us_bank_account, etc.
  last4                 String?
  brand                 String?
  expMonth              Int?
  expYear               Int?
  isDefault             Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payout {
  id               String      @id @default(cuid())
  creatorProfileId String
  stripePayoutId   String?     @unique
  amount           Float
  currency         String      @default("usd")
  status           PayoutStatus @default(PENDING)
  arrivalDate      DateTime?
  description      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id])

  @@index([creatorProfileId])
  @@index([status])
}

model Transaction {
  id               String          @id @default(cuid())
  type             TransactionType
  userId           String
  creatorProfileId String?
  amount           Float           // gross amount in dollars
  platformFee      Float           @default(0)
  netAmount        Float           // amount after platform fee
  currency         String          @default("usd")
  stripeId         String?         // stripe payment intent, subscription, etc.
  metadata         Json?
  description      String?

  createdAt DateTime @default(now())

  user           User            @relation("UserTransactions", fields: [userId], references: [id])
  creatorProfile CreatorProfile? @relation("CreatorTransactions", fields: [creatorProfileId], references: [id])

  @@index([userId])
  @@index([creatorProfileId])
  @@index([type])
  @@index([createdAt])
}

// ─── Notification & Audit ─────────────────────────────────────────────────────

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  title   String
  body    String
  data    Json?
  isRead  Boolean          @default(false)
  readAt  DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model AuditLog {
  id       String  @id @default(cuid())
  userId   String?
  action   String
  entity   String
  entityId String?
  metadata Json?
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model CreatorVerification {
  id                String             @id @default(cuid())
  creatorProfileId  String             @unique
  encryptedLegalName String
  encryptedIdFront  String?
  encryptedIdBack   String?
  dateOfBirth       DateTime?
  verifiedAt        DateTime?
  status            VerificationStatus @default(PENDING)
  reviewedBy        String?
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@index([status])
}

// ─── Cron Job State ──────────────────────────────────────────────────────────

model TravelPriceHistory {
  id        String   @id @default(cuid())
  dealKey   String   // e.g. "YVR-LAX-hotel-beachfront-4star"
  price     Float
  label     String   // human-readable description
  createdAt DateTime @default(now())

  @@index([dealKey])
  @@index([createdAt])
}

model SeenEvent {
  id        String   @id @default(cuid())
  hash      String   @unique // MD5 of "name|venue|date"
  createdAt DateTime @default(now())
}
